# ==============================================================================
# CLAUDE CODE RUNTIME
# ==============================================================================
.claude/*
# track the shared plugin-enable config + the committed output style; personal settings.local.json stays ignored (*.local.json below)
!.claude/settings.json
!.claude/output-styles/
# advisor panel is version-controlled (see pdca-init panel-generation)
!.claude/agents/
**/compressed_context.md

# ==============================================================================
# MACHINE/SESSION SPECIFIC
# ==============================================================================
*.local.json
*.local.md

# ==============================================================================
# PYTHON
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
*.egg
.venv/
venv/
ENV/

# ==============================================================================
# NODE.JS
# ==============================================================================
node_modules/
npm-debug.log*
yarn-error.log*
.npm

# ==============================================================================
# OS FILES
# ==============================================================================
.DS_Store
*:Zone.Identifier
Thumbs.db
*.swp
*.swo
*~

# ==============================================================================
# EDITORS/IDE
# ==============================================================================
.vscode/
.idea/
*.sublime-*

# ==============================================================================
# SECRETS (never track)
# ==============================================================================
.env
.env.*
*.key
*.pem
credentials.json
secrets.json

# ==============================================================================
# BUILD/TEMP
# ==============================================================================
dist/
build/
*.log
*.tmp
*.temp

# ==============================================================================
# EXPERIMENTS (not for tracking)
# ==============================================================================
experiment/
